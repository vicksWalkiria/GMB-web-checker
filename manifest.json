{
  "manifest_version": 3,
  "name": "GMB-Web Coherence Checker",
  "version": "1.0.0",
  "description": "Evalúa la coherencia SEO local entre una ficha de Google Maps/Search y la web oficial.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Analizar Coherencia Local"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
